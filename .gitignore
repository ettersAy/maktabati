cat > .gitignore <<EOF
# Dependencies
node_modules/

# VitePress Build & Cache
docs/.vitepress/dist/
docs/.vitepress/cache/

# Editor Backups & Swaps
*~
*.swp
*.swo
.DS_Store

# Environment Variables
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
EOF

# Playwright artifacts
playwright-report/
test-results/
